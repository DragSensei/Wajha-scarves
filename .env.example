# Wajha Scarves - Environment Configuration Template

# Flask Environment Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Security Secrets (Must be changed in production!)
SECRET_KEY=default_secret_key_change_me
ADMIN_PASSWORD=default_admin_password_change_me

# JWT Authentication Config
JWT_SECRET=default_jwt_secret_change_me
JWT_ALGORITHM=HS256
JWT_ISSUER=

# Database Connection (Neon Postgres url in prod, leaves empty for local SQLite app.db fallback)
DATABASE_URL=

# Session and Cookie Security settings
SESSION_COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Authentication Mode ('local' or 'external')
AUTH_MODE=local
AUTH_REGISTRATION_ENABLED=True

# Optional: Vercel Blob storage token for product image uploads.
# If omitted/empty, the server will default to local file storage.
BLOB_READ_WRITE_TOKEN=
